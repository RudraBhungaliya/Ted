{
    "compilerOptions": {
        "target": "ES2022",

        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "strict": true,

        "esModuleInterop": true,

        "allowSyntheticDefaultImports": true,

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "resolveJsonModule": true,

        "isolatedModules": true,

        "types": ["node"],

        "outDir": "dist",
        "rootDir": "./src",


        "baseUrl": "./src",

        "paths": {
            "@/*": ["*"]
        }
    },

    "include": ["src"]
}