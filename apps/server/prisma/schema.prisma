generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

model User {

  id String @id @default(cuid())

  fullName String?

  email String @unique

  password String?

  googleId String? @unique

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  sessions Session[]

  subscription Subscription?

  usage Usage?
}

model Subscription {

  id String @id @default(cuid())

  userId String @unique

  plan SubscriptionPlan @default(FREE)

  active Boolean @default(true)

  startedAt DateTime @default(now())

  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Usage {

  id String @id @default(cuid())

  userId String @unique

  totalSessions Int @default(0)

  totalMinutes Int @default(0)

  totalTokens Int @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {

  id String @id @default(cuid())

  userId String

  title String?

  status SessionStatus @default(ACTIVE)

  startedAt DateTime @default(now())

  endedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  mode String @default("interview")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transcripts Transcript[]

  aiMessages AiMessage[]

  analytics AnswerAnalytics[]

  summary InterviewSummary?
}

model Transcript {

  id String @id @default(cuid())

  sessionId String

  speaker String @default("user")

  text String @db.Text

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AiMessage {

  id String @id @default(cuid())

  sessionId String

  provider String?

  model String?

  text String @db.Text

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AnswerAnalytics {

  id String @id @default(cuid())

  sessionId String

  totalWords Int

  fillerCount Int

  confidenceScore Int

  usesStarFormat Boolean

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InterviewSummary {

  sessionId String @id

  score Int

  strengths String[]

  weaknesses String[]

  recommendations String[]

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}