{
  "manifest_version": 3,
  "name": "Ted Assistant Overlay",
  "version": "1.0",
  "description": "Real-time AI floating overlay for interviews, Zoom, and Google Meet",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ]
}
